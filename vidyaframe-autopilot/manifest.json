{
  "manifest_version": 3,
  "name": "VidyaFrame AutoPilot",
  "version": "1.0.0",
  "description": "Automated prompt queue and ChatGPT integration for VidyaFrame Prompt Studio — batch generate educational charts and worksheets.",
  
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "alarms",
    "scripting",
    "notifications"
  ],
  
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*",
    "file:///*"
  ],

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "http://localhost:*/*",
        "http://127.0.0.1:*/*",
        "file:///*"
      ],
      "js": ["lib/constants.js", "lib/prompt-builder.js", "content-scripts/prompt-studio.js"],
      "css": ["content-scripts/prompt-studio.css"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["lib/constants.js", "lib/generation-detector.js", "content-scripts/chatgpt-agent.js"],
      "css": ["content-scripts/chatgpt-agent.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["data/topics.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
